VITE_APP_VERSION=v1.0.0
GENERATE_SOURCEMAP=false

NODE_ENV=development
RUN_MIGRATIONS_ON_START=false
APP_BASE_URL=http://localhost:3000
LOCAL_APP_BASE_URL=http://localhost:3000
VITE_APP_BASE_NAME=/
VITE_APP_API_BASE=/api
VITE_DEV_LOGIN=false
# Dashboard (anchor-hub) origin — used for cross-app SSO: the Task Manager fetches
# its access token from the dashboard's /api/auth/refresh using the shared same-site
# login cookie (both run under *.anchorcorps.com).
VITE_MAIN_APP_URL=https://dashboard.anchorcorps.com

GOOGLE_CLOUD_PROJECT=anchor-hub-480305
GOOGLE_CLOUD_REGION=us-central1
VERTEX_MODEL=gemini-2.0-flash

CORS_ORIGINS=http://localhost:3000,http://localhost:4173
UPLOAD_DIR=uploads

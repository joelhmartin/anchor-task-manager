# =============================================================================
# Anchor Task Manager — Environment Variables
# Copy to .env and fill in. The Task Manager is a staff tool and an SSO consumer
# of the main app (anchor-hub); it owns its own Postgres database.
# =============================================================================

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# The Task Manager's OWN database (own Cloud SQL DB / local Postgres).
DATABASE_URL=postgres://tasks_app:CHANGE_ME@localhost:5432/anchor_tasks
# Run schema migrations on boot (init + security + activity_logs + task incrementals).
RUN_MIGRATIONS_ON_START=false
# Comma-separated extra CORS origins (the main app origin is added automatically).
CORS_ORIGINS=
# Where task file attachments are written (ephemeral on Cloud Run).
UPLOAD_DIR=uploads

# ── SSO ─────────────────────────────────────────────────────────────────────
# MUST be byte-identical to the main app's JWT secret
# (Secret Manager: anchor-jwt-signing-secret) so logins minted by main are accepted.
JWT_SECRET=CHANGE_ME_TO_MATCH_MAIN_APP
ACCESS_TOKEN_LIFETIME_SEC=900
# Local login shim (POST /api/auth/login). Set false in production once SSO is wired.
DEV_LOGIN=true

# ── Cross-app links ─────────────────────────────────────────────────────────
# Main app base URL — SSO handoff + client roster API (board → client labels).
MAIN_APP_URL=
# Optional service token the Task Manager presents to the main app's roster API.
MAIN_APP_SERVICE_TOKEN=

# ── Encryption (optional) ───────────────────────────────────────────────────
# Only needed if this app stores encrypted data. If shared with main, must match
# Secret Manager: anchor-aes-encryption-key.
ENCRYPTION_KEY=

# ── Email (optional — task automation notifications via Mailgun) ────────────
# Leave unset to disable outbound email.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_DEFAULT_FROM=
ADMIN_NOTIFICATION_EMAIL=

# ── AI task summaries (optional — Vertex AI / Gemini) ───────────────────────
GOOGLE_CLOUD_PROJECT=anchor-hub-480305
GOOGLE_CLOUD_REGION=us-central1
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=

# ── Misc ────────────────────────────────────────────────────────────────────
# Cron timezone for the task scheduled jobs.
CRON_TIMEZONE=America/New_York
# Archived task items are purged after this many days.
TASK_ARCHIVE_RETENTION_DAYS=30
# Enable the in-process task event bus subscribers.
TASK_EVENT_BUS_ENABLED=true

# ── Frontend (Vite — VITE_* are inlined at build time) ──────────────────────
VITE_APP_API_BASE=/api
VITE_APP_VERSION=1.0.0
# Main app URL for the login "continue in Anchor Hub" handoff.
VITE_MAIN_APP_URL=
# Show the dev login form on the login page (set false in production).
VITE_DEV_LOGIN=true

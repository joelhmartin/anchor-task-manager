# =============================================================================
# Anchor Client Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control - it contains secrets!
# =============================================================================

# -----------------------------------------------------------------------------
# CORE APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
API_SERVER_PORT=4000

# Base URLs (used for emails, redirects, CORS)
APP_BASE_URL=http://localhost:3000
CLIENT_APP_URL=http://localhost:3000
LOCAL_APP_BASE_URL=http://localhost:3000
# API_BASE_URL=http://localhost:4000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4173

# File uploads directory
UPLOAD_DIR=uploads

# Run database migrations on server start (true in production)
RUN_MIGRATIONS_ON_START=true

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://username:password@localhost:5432/anchor_dashboard

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# JWT secret - REQUIRED in production (generate with: openssl rand -hex 64)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Encryption key for sensitive data (32-byte hex string)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Token lifetimes
ACCESS_TOKEN_LIFETIME_SEC=900          # 15 minutes
REFRESH_TOKEN_LIFETIME_DAYS=30
ABSOLUTE_SESSION_LIFETIME_DAYS=90

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_RESET_TTL_MINUTES=60

# Rate limiting
LOGIN_RATE_LIMIT_IP_MAX=10
LOGIN_RATE_LIMIT_IP_WINDOW=15          # minutes
LOGIN_RATE_LIMIT_IP_LOCKOUT=15         # minutes
LOGIN_RATE_LIMIT_USER_MAX=5
LOGIN_RATE_LIMIT_USER_WINDOW=15        # minutes
LOGIN_RATE_LIMIT_USER_LOCKOUT=30       # minutes
MAX_LOGIN_FAILURES=5
ACCOUNT_LOCKOUT_MINUTES=30

# MFA settings
MFA_OTP_EXPIRY_MINUTES=10
MFA_MAX_ATTEMPTS=5
MFA_INACTIVITY_DAYS=30
DEVICE_TRUST_DAYS=30
# REVOKE_SESSIONS_ON_MFA_CHANGE=true

# IP/fingerprint hashing salt
IP_HASH_SALT=your-random-salt-here
RATE_LIMIT_SALT=your-rate-limit-salt

# -----------------------------------------------------------------------------
# GOOGLE CLOUD / VERTEX AI
# -----------------------------------------------------------------------------
# Google Cloud project configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Vertex AI (Gemini) settings
VERTEX_PROJECT_ID=your-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash
VERTEX_CLASSIFIER_MODEL=gemini-2.0-flash
# VERTEX_IMAGEN_MODEL=imagen-3.0-generate-001

# -----------------------------------------------------------------------------
# ADMIN AUDITS (Vertex AI)
# -----------------------------------------------------------------------------
ANALYTICS_AUDIT_RUNNER_SECRET=replace-with-a-long-random-secret
# AUDIT_MODEL_VERTEX=gemini-2.5-flash

# Document AI processors
# DOCUMENTAI_LAYOUT_PROCESSOR_ID=
# DOCUMENTAI_FORM_PROCESSOR_ID=
# DOCUMENTAI_LOCATION=us

# -----------------------------------------------------------------------------
# GOOGLE OAUTH (for client integrations)
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# MAILGUN (Email)
# -----------------------------------------------------------------------------
# Production
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_DEFAULT_FROM=Anchor Dashboard <noreply@yourdomain.com>
MAILGUN_WEBHOOK_SIGNING_KEY=your-webhook-signing-key

# Sandbox/Development (optional)
# MAILGUN_SANDBOX_API_KEY=
# MAILGUN_SANDBOX_DOMAIN=

# Admin notification fallback email
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# -----------------------------------------------------------------------------
# CALLTRACKINGMETRICS (CTM)
# -----------------------------------------------------------------------------
CTM_API_BASE=https://api.calltrackingmetrics.com
# CTM credentials are stored per-client in the database
# CTM_MAX_CALLS=200
# CTM_CLASSIFY_LIMIT=40
# CTM_FULL_SYNC_DAYS=365

# Default AI prompt for call classification (optional)
# DEFAULT_AI_PROMPT=
# Console-only verbose AI classification debugging. Persistent AI classification
# review logs are always stored in the database.
# AI_CLASSIFICATION_DEBUG=false
# Retention for persisted AI classification review logs (capped at 30 days)
# AI_CLASSIFICATION_LOG_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# TWILIO (Voice/SMS)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# -----------------------------------------------------------------------------
# FACEBOOK/META (OAuth Integration)
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# -----------------------------------------------------------------------------
# TIKTOK (OAuth Integration)
# -----------------------------------------------------------------------------
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# WORDPRESS (OAuth Integration)
# -----------------------------------------------------------------------------
# WORDPRESS_CLIENT_ID=
# WORDPRESS_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# VIMEO (Direct file URL resolution for social video publishing)
# -----------------------------------------------------------------------------
VIMEO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# SOCIAL MEDIA TOKENS (HMAC-SHA256 signing key for public media fetch route)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
SOCIAL_MEDIA_SECRET=

# -----------------------------------------------------------------------------
# ONBOARDING SETTINGS
# -----------------------------------------------------------------------------
ONBOARDING_TOKEN_TTL_HOURS=720         # 30 days
ONBOARDING_BRAND_UPLOAD_MAX_BYTES=26214400  # 25MB
CLIENT_INVITE_TOKEN_TTL_HOURS=72       # 3 days

# -----------------------------------------------------------------------------
# DATA RETENTION (Compliance)
# -----------------------------------------------------------------------------
ACTIVITY_LOG_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=730           # 2 years (HIPAA)
TASK_ARCHIVE_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# CONTENT SECURITY POLICY (Optional)
# -----------------------------------------------------------------------------
# CSP_FRAME_SRC=https://trusted-domain.com
# CSP_IMG_SRC=https://trusted-image-cdn.com

# -----------------------------------------------------------------------------
# BLOG/CONTENT GENERATION
# -----------------------------------------------------------------------------
# BLOG_DRAFT_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# PDF PROCESSING
# -----------------------------------------------------------------------------
# FORMS_PDF_RASTERIZER=auto             # auto, imagemagick, or sharp

# -----------------------------------------------------------------------------
# DEFAULT DOCUMENTS (JSON array of document URLs for new clients)
# -----------------------------------------------------------------------------
# DEFAULT_DOCS=[]

# -----------------------------------------------------------------------------
# VITE FRONTEND VARIABLES (must be prefixed with VITE_)
# -----------------------------------------------------------------------------
VITE_APP_VERSION=v5.0.0
VITE_APP_BASE_NAME=/
VITE_APP_API_BASE=/api
GENERATE_SOURCEMAP=false

# Report Builder (Phase 1)
# 32-byte hex string used to sign internal render-route tokens.
# Generate with: openssl rand -hex 32
REPORT_RENDER_SECRET=

# Used by the Puppeteer PDF renderer to call back into the same server.
# Default works locally; in container deployments where PORT differs or the loopback
# is restricted, set this explicitly (e.g. http://localhost:8080 on Cloud Run).
INTERNAL_BASE_URL=
